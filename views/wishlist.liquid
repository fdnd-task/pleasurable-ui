{% include 'partials/head.liquid' %}
<style>
  .grid_likedproducts {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;

    .opgeslagen-product {
      background-color: white;
      border-radius: 25px;

      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);

      padding: 20px;
      width: 300px;
    }

    .lijst-button {
      background-color: #20a687;
      color: white;
      border: none;
      border-radius: 8px;
      padding: 10px 25px;
      font-size: 20px;
      font-weight: bold;
      cursor: pointer;
      transition: 0.2s;
    }
  }

 .slider {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;

  input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .circle {
    display: none;

    width: 60px;
    height: 60px;

    border: 2px solid goldenrod;
    border-radius: 50%;

    place-items: center;
    cursor: pointer;

    transition:
      width 0.3s ease,
      height 0.3s ease;

    img {
      width: 28px;
      height: 28px;
      object-fit: contain;
    }
  }

  .next {
    display: none;
    padding: 0.4rem 0.8rem;
    background: goldenrod;
    color: white;
    border-radius: 4px;
    cursor: pointer;
  }

  /* toon steeds 2 circles op mobiel */
#step1:checked ~ .circle[for="step1"],
#step1:checked ~ .circle[for="step2"],
#step2:checked ~ .circle[for="step2"],
#step2:checked ~ .circle[for="step3"],
#step3:checked ~ .circle[for="step3"],
#step3:checked ~ .circle[for="step4"],
#step4:checked ~ .circle[for="step4"],
#step4:checked ~ .circle[for="step5"],
#step5:checked ~ .circle[for="step5"],
#step5:checked ~ .circle[for="step6"],
#step6:checked ~ .circle[for="step6"],
#step6:checked ~ .circle[for="step7"],
#step7:checked ~ .circle[for="step7"],
#step7:checked ~ .circle[for="step8"],
#step8:checked ~ .circle[for="step8"],
#step8:checked ~ .circle[for="step1"] {
  display: grid;
}

/* actieve circle groter */
#step1:checked ~ .circle[for="step1"],
#step2:checked ~ .circle[for="step2"],
#step3:checked ~ .circle[for="step3"],
#step4:checked ~ .circle[for="step4"],
#step5:checked ~ .circle[for="step5"],
#step6:checked ~ .circle[for="step6"],
#step7:checked ~ .circle[for="step7"],
#step8:checked ~ .circle[for="step8"] {
  width: 90px;
  height: 90px;
}

/* alleen juiste next knop tonen */
#step1:checked ~ .next-1,
#step2:checked ~ .next-2,
#step3:checked ~ .next-3,
#step4:checked ~ .next-4,
#step5:checked ~ .next-5,
#step6:checked ~ .next-6,
#step7:checked ~ .next-7,
#step8:checked ~ .next-8 {
  display: inline-flex;
}

  @media (min-width: 768px) {
    .circle {
      display: grid;
    }

    .next {
      display: none !important;
    }
  }
}
</style>



 <div class="slider">

  <!-- states -->

  <input type="radio" name="step" id="step1" checked>
  <input type="radio" name="step" id="step2">
  <input type="radio" name="step" id="step3">
  <input type="radio" name="step" id="step4">
  <input type="radio" name="step" id="step5">
  <input type="radio" name="step" id="step6">
  <input type="radio" name="step" id="step7">
  <input type="radio" name="step" id="step8">

  <!-- circles -->

  <label for="step1" class="circle">
    <img src="/assets/images/wishlist-icon.svg" alt="">
  </label>

  <label for="step2" class="circle">
    <img src="/assets/images/wishlist-icon.svg" alt="">
  </label>

  <label for="step3" class="circle">
    <img src="/assets/images/wishlist-icon.svg" alt="">
  </label>

  <label for="step4" class="circle">
    <img src="/assets/images/wishlist-icon.svg" alt="">
  </label>

  <label for="step5" class="circle">
    <img src="/assets/images/wishlist-icon.svg" alt="">
  </label>

  <label for="step6" class="circle">
    <img src="/assets/images/wishlist-icon.svg" alt="">
  </label>

  <label for="step7" class="circle">
    <img src="/assets/images/wishlist-icon.svg" alt="">
  </label>

  <label for="step8" class="circle">
    <img src="/assets/images/wishlist-icon.svg" alt="">
  </label>

  <!-- mobile next buttons -->

  <label for="step2" class="next next-1">→</label>
  <label for="step3" class="next next-2">→</label>
  <label for="step4" class="next next-3">→</label>
  <label for="step5" class="next next-4">→</label>
  <label for="step6" class="next next-5">→</label>
  <label for="step7" class="next next-6">→</label>
  <label for="step8" class="next next-7">→</label>
  <label for="step1" class="next next-8">→</label>

</div>

<main class="grid_likedproducts">
  <article class="opgeslagen-product">
    <img src="" alt="producten">
    <h2>test</h2>
    <p>bedrag</p>

    <form method="post" action="" class="like-form">
      <input type="hidden" name="id" value="{{ product.id }}">

      <button type="submit" class="lijst-button">
        <img class="verwijder" src="" alt="lijst">
      </button>
    </form>
  </article>
</main>

{% include 'partials/foot.liquid' %}
