    <li>{% render './partials/link-button.liquid', link: '#', text: 'Contact', style: 'nav-link' %}</li>
  </ul>
</header>

<nav class="desktop-nav">
  <div class="desktop-nav-container">
  <a href="/"><img src="/assets/logo-light.svg" alt="Logo"></a>

  <div class="link-and-button-desktop">

  <ul class="link-nav">
    <li>{% render './partials/link-button.liquid', link: '#', text: 'Home', style: 'nav-link' %}</li>
    <li>{% render './partials/link-button.liquid', link: '#', text: 'Over Ads', style: 'nav-link' %}</li>
