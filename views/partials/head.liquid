    <li>{% render './partials/link-button.liquid', link: '#', text: 'Nieuws', style: 'nav-link' %}</li>
  </ul>

  {% render './partials/link-button.liquid', link: '#', text: 'Kom naar Ad-dag', style: 'secondary-button-mobile-nav' %}
