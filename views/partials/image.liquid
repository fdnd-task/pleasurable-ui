{% comment %}
  first if that checks if the image is in the local map

  this is how you type the partial

  {% render 'partials/image.liquid',
    imageSrc: 'assets/images/heronews',
    width: '50',
    height: '50',
    alt: 'hero foto',
    fetch: 'auto',
    loading: 'lazy'
  %}
{% endcomment %}

{% if imageSrc contains 'assets/images' %}
  <picture>
    <source
      srcset="{{ imageSrc }}.avif?width={{ width }}&height={{ height }}&quality=70"
      type="image/avif"
    >
    <source
      srcset="{{ imageSrc }}.webp?width={{ width }}&height={{ height }}&quality=70"
      type="image/webp"
    >
    <img
      class="{{ class }}"
      src="{{ imageSrc }}?width={{ width }}&height={{ height }}&quality=60"
      width="{{ width }}"
      height="{{ height }}"
      fetchpriority="{{ fetch }}"
      loading="{{ loading }}"
      alt="{{ alt }}"
    >
  </picture>

{% else %}
  {% comment %}
    image out of database directus
  {% endcomment %}
  <picture>
    <source
      srcset="{{ imageSrc }}?width={{ width }}&height={{ height }}&format=avif&quality=70"
      type="image/avif"
    >
    <source
      srcset="{{ imageSrc }}?width={{ width }}&height={{ height }}&format=webp&quality=70"
      type="image/webp"
    >
    <img
      class="{{ class }}"
      src="{{ imageSrc }}?width={{ width }}&height={{ height }}&quality=60"
      width="{{ width }}"
      height="{{ height }}"
      fetchpriority="{{ fetch }}"
      loading="{{ loading }}"
      alt="{{ alt }}"
    >
  </picture>
{% endif %}
