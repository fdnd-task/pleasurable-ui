{% comment %} this is to preview the news card the page will be updated in an other pull request  {% endcomment %}
<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="css/styleguide.css">
    <link rel="stylesheet" href="css/style.css">
    <title>Nieuws</title>
  </head>
  <body>
    <section>
      {% comment %} hero partial {% endcomment %}
    </section>

    {% comment %}
      <section class="container news-grid">
        {% for newsArticle in news limit: 3 %}
          {% render 'partials/news-card.liquid',
            date: newsArticle.date,
            title: newsArticle.title,
            description: newsArticle.description
          %}
        {% endfor %}
      </section>
    {% endcomment %}

    <section class="container news-grid">
      {% for newsArticle in news %}
        {% render 'partials/news-card.liquid',
          date: newsArticle.date,
          title: newsArticle.title,
          description: newsArticle.description
        %}
      {% endfor %}
    </section>

    {% render './partials/footer.liquid' %}
  </body>
</html>
