<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="css/styleguide.css">
    <link rel="stylesheet" href="css/style.css">
    <title>Document</title>
  </head>
  <body>
    {% assign contentVar = 'Oeps! De pagina die probeert te bereiken lijkt niet te bestaan. Klik op de knop hieronder om weer terug te gaan naar de home pagina.' %}
    {% assign imgURL = 'assets/images/mascot-ad' %}
    {% comment %} should be converted to a header when possible for the H1 tag {% endcomment %}
    {% render './partials/article.liquid',
      style: '',
      title: 'Pagina niet gevonden',
      content: contentVar,
      imgURL: imgURL,
      imgWidth: 300,
      imgHeight: 300,
      imgAlt: 'alt tekst voor img',
      imgFetch: 'auto',
      imgLoading: 'lazy',
      button: true,
      btnLink: '/',
      btnText: 'Terug naar home',
      btnStyle: 'primary-button'
    %}
    {% render 'partials/footer.liquid' %}
  </body>
</html>
